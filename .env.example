# ── Deployment ────────────────────────────────────────────────────────────────
# Public URL of your app. Change this when deploying to a cloud host.
# Local:   http://localhost:8000
# Render:  https://your-app-name.onrender.com
# Fly.io:  https://your-app-name.fly.dev
BASE_URL=http://localhost:8000
PORT=8000

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default, works everywhere — good for single-server deployments)
DATABASE_URL=sqlite+aiosqlite:///./uplinx.db
# PostgreSQL (uncomment for managed cloud DBs)
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# ── Meta (Facebook & Instagram) ───────────────────────────────────────────────
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_API_VERSION=v21.0
# OAuth redirect URI — must exactly match what's registered in your Meta App.
# When deploying, set this to: https://your-host.com/auth/meta/callback
META_REDIRECT_URI=http://localhost:8000/auth/meta/callback

# ── Google OAuth (optional) ───────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
# When deploying, set this to: https://your-host.com/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ── AI Provider ───────────────────────────────────────────────────────────────
# Active provider: claude | openai | groq
AI_PROVIDER=claude
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-7

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-use-a-long-random-string
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ── Team Access (optional) ───────────────────────────────────────────────────
# Set a shared password to protect the app with a login screen.
# Leave blank to skip the login screen.
LOGIN_PASSWORD=

# ── CORS (optional) ───────────────────────────────────────────────────────────
# Leave blank — CORS origins are auto-derived from BASE_URL.
# Override with a comma-separated list if you need custom origins.
CORS_ORIGINS=

# ── App Settings ──────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=100
CACHE_TTL_SECONDS=3600
LOG_LEVEL=INFO
AUTO_CLEAR_UPLOADS_HOURS=24
